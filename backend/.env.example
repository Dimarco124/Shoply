# Copier en .env et remplir (pour la production, ces variables se mettent sur Render)
# En local, le fichier .env est optionnel (valeurs par défaut dans settings.py)

SECRET_KEY=votre-clé-secrète-longue-et-aléatoire
DEBUG=False
ALLOWED_HOSTS=.onrender.com,localhost,127.0.0.1
DATABASE_URL=postgres://user:password@host:port/dbname
CORS_ALLOWED_ORIGINS=https://votre-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=https://votre-backend.onrender.com
